# ---------------------------------------------------------------------------
# Copy to .env.local for local dev, or set these in Vercel's dashboard.
# The key is used ONLY server-side (in /api/generate) — never sent to browsers.
# ---------------------------------------------------------------------------

# Provider: anthropic | openai | google | compatible | ollama
LLM_PROVIDER=anthropic

# Your API key. NOT needed when LLM_PROVIDER=ollama (local, free).
LLM_API_KEY=your-key-here

# Model id. Defaults if blank:
#   anthropic -> claude-sonnet-5   | openai -> gpt-4o-mini
#   google    -> gemini-1.5-flash  | ollama -> llama3.1:8b
LLM_MODEL=

# Only for LLM_PROVIDER=compatible (OpenRouter, Groq, Together…)
# or to override Ollama's address (default http://localhost:11434/v1)
LLM_BASE_URL=

# ---------------------------------------------------------------------------
# RUN 100% FREE & OFFLINE WITH OLLAMA
#   1. Install Ollama:  https://ollama.com/download
#   2. ollama pull llama3.1:8b
#   3. LLM_PROVIDER=ollama   /   LLM_MODEL=llama3.1:8b   /  leave key blank
#   4. vercel dev
#
#   Ollama only works when you run this app on YOUR OWN machine.
#   A Vercel deployment cannot reach localhost on your computer.
# ---------------------------------------------------------------------------
